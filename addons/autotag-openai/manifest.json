{
  "name": "autotag-openai",
  "version": "1.0.0",
  "capabilities": ["classify"],
  "description": "Auto-tag photos via OpenAI Vision API (or compatible endpoint)",
  "config_schema": [
    {
      "key": "api_key",
      "label": "API key",
      "kind": "secret"
    },
    {
      "key": "api_endpoint",
      "label": "Endpoint",
      "kind": "text",
      "default": "https://api.openai.com/v1/chat/completions"
    },
    {
      "key": "detail",
      "label": "Image detail level",
      "kind": "select",
      "options": ["low", "high", "auto"],
      "default": "low"
    },
    {
      "key": "vocabulary_file",
      "label": "Vocabulary file (one tag per line, blank = built-in 49 tags)",
      "kind": "text"
    }
  ]
}
